{
  "expo": {
    "name": "AutoMate",
    "slug": "automate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "automate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F4F1"
    },
    "ios": {
      "bundleIdentifier": "com.arctosbuilt.automate",
      "supportsTablet": true,
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#F5F4F1",
        "dark": {
          "image": "./assets/images/splash-icon-dark.png",
          "backgroundColor": "#0E0E0C"
        }
      },
      "infoPlist": {
        "NSCameraUsageDescription": "AutoMate uses your camera to take photos of receipts and your vehicle.",
        "NSPhotoLibraryUsageDescription": "AutoMate accesses your photo library to attach receipt images to events.",
        "NSLocationWhenInUseUsageDescription": "AutoMate uses your location to identify nearby gas stations and service shops."
      }
    },
    "android": {
      "package": "com.arctosbuilt.automate",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0E0E0C"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#F5F4F1",
        "dark": {
          "image": "./assets/images/splash-icon-dark.png",
          "backgroundColor": "#0E0E0C"
        }
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#4272C4"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "AutoMate uses your camera to take photos of receipts and your vehicle.",
          "photosPermission": "AutoMate accesses your photo library to attach receipt images."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "AutoMate uses your location to identify nearby gas stations and service shops."
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9f8bbe5a-60e6-41c6-9670-3d51ba70c47c"
      }
    }
  }
}
